# sudoers-dispatch-svc.tmpl — sudoers fragment for the dispatch service user.
# This file is rendered by setup-dispatch-host.sh and installed to
# /etc/sudoers.d/dispatch-svc after validation with visudo -c.
#
# {{SERVICE_USER}} = the dispatch service user (default: dispatch-svc)
# {{AGENT_USER}}   = the agent subprocess user (default: dispatch)

{{SERVICE_USER}} ALL=({{AGENT_USER}}) NOPASSWD: /usr/bin/git, /home/{{AGENT_USER}}/.local/bin/uv, /usr/bin/claude, /usr/bin/python3, /bin/bash
