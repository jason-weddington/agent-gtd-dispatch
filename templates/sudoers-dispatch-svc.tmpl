# sudoers-dispatch-svc.tmpl — sudoers fragment for the dispatch service user.
# This file is rendered by setup-dispatch-host.sh and installed to
# /etc/sudoers.d/dispatch-svc after validation with visudo -c.
#
# {{SERVICE_USER}} = the dispatch service user (default: dispatch-svc)
# {{AGENT_USER}}   = the agent subprocess user (default: dispatch)

# Environment variables that must survive the sudo boundary.
# CLAUDE_CODE_OAUTH_TOKEN  — Claude Code OAuth credential (auth to Anthropic)
# ANTHROPIC_API_KEY        — Anthropic API key (auth to Anthropic API)
# ANTHROPIC_BASE_URL       — Claude Code endpoint override for the Ollama-routed
#                            claude-code-ollama (local) + claude-code-glm (cloud)
#                            engines; without it Claude Code hits the default
#                            Anthropic API and the Ollama routing silently no-ops.
# ANTHROPIC_AUTH_TOKEN     — Bearer token for the ANTHROPIC_BASE_URL endpoint above
#                            (claude-code-glm ships the Ollama-cloud key here). Same
#                            silent-no-op failure mode if stripped.
# AGENT_GTD_URL            — Agent GTD API base URL (task management)
# AGENT_GTD_API_KEY        — Agent GTD API key (auth to task management)
# DISPATCH_API_KEY         — Dispatch service bearer token (internal auth)
# KB_DATABASE_URL          — Knowledge base database URL (agent KB access)
# OLLAMA_BASE_URL          — Ollama API base URL (local LLM access)
# AGENT_GTD_AGENT_NAME     — Agent identity name (for GTD comment attribution)
# ANTHROPIC_MODEL          — talos-sonnet/opus model pin; without it talos falls
#                            back to its default (haiku) — silent downgrade.
# TALOS_BACKEND            — talos backend selector (anthropic|ollama); without
#                            it talos defaults to anthropic, breaking talos-glm/qwen.
# OLLAMA_MODEL             — talos-glm/qwen model pin (glm-5.2:cloud, qwen3.6:35b).
# OLLAMA_API_KEY           — Ollama cloud/local key for talos ollama backends.
# OLLAMA_THINK             — talos-qwen thinking-mode toggle.
# OLLAMA_NUM_CTX           — talos-qwen context-window pin (32768).
# PATH                     — Required so uvx/MCP binaries in ~/.local/bin survive env_reset
#
# NOTE: talos per-engine env is built by talos_env_overlay and passed on the
# subprocess env, but the dispatch-svc→AGENT_USER sudo hop applies env_reset —
# so every var the talos subprocess needs MUST be listed here or it is stripped.
# The ollama vars carry no default fallback, so their omission fails the run
# outright; ANTHROPIC_MODEL's omission fails silently (downgrades to haiku).
Defaults:{{SERVICE_USER}} env_keep += "CLAUDE_CODE_OAUTH_TOKEN ANTHROPIC_API_KEY ANTHROPIC_BASE_URL ANTHROPIC_AUTH_TOKEN ANTHROPIC_MODEL AGENT_GTD_URL AGENT_GTD_API_KEY DISPATCH_API_KEY KB_DATABASE_URL OLLAMA_BASE_URL OLLAMA_MODEL OLLAMA_API_KEY OLLAMA_THINK OLLAMA_NUM_CTX TALOS_BACKEND AGENT_GTD_AGENT_NAME PATH"

# Override secure_path to include ~/.cargo/bin and ~/.local/bin for the agent user, so
# cargo/cargo-nextest (gate command for talos ChecksRunner) and uvx/MCP binaries installed
# to the agent user's ~/.local/bin are discoverable and executable even after sudo's
# env_reset applies secure_path. .cargo/bin is prepended so it is searched first.
Defaults:{{SERVICE_USER}} secure_path="/home/{{AGENT_USER}}/.cargo/bin:/home/{{AGENT_USER}}/.local/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin"

# claude lives at /usr/local/bin/claude on disk but resolves to the symlink
# target /home/{{AGENT_USER}}/.local/bin/claude when secure_path is searched —
# sudo matches the resolved path, not the symlink. Both paths must be
# authorised so NOPASSWD survives whichever order secure_path resolves first.
# talos is installed to /home/{{AGENT_USER}}/.local/bin/talos (copy, not symlink) by
# setup-dispatch-host.sh --with-talos; it must be authorised here so the
# dispatch-svc→dispatch sudo-wrapped invocation (talos.py _sudo_wrap) is not DENIED.
{{SERVICE_USER}} ALL=({{AGENT_USER}}) NOPASSWD: /usr/bin/git, /home/{{AGENT_USER}}/.local/bin/uv, /home/{{AGENT_USER}}/.local/bin/claude, /usr/local/bin/claude, /usr/bin/rm, /usr/bin/python3, /bin/bash, /usr/bin/mkdir, /home/{{AGENT_USER}}/.local/bin/talos
