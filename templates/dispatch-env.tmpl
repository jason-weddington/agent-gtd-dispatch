# dispatch-env.tmpl — environment file template for the dispatch service.
# Two-user: copy to /home/dispatch-svc/.env. Single-user: copy to ~/.config/agent-gtd-dispatch/env. Fill in real values.
# All lines beginning with # are comments.

# =============================================================================
# Required variables
# =============================================================================

# Dispatch API auth — callers must provide this as a Bearer token.
# Auto-minted by setup-dispatch-host.sh Step 3.5 if left empty. Leave blank for fresh installs;
# do NOT clear an existing value on a true-up run (would silently break app-side pairing —
# re-register the new value in the GTD UI manually if rotating).
DISPATCH_API_KEY=

# Agent GTD API (for fetching items/projects and posting comments).
AGENT_GTD_URL=https://r7-research:8443
AGENT_GTD_API_KEY=agtd_...

# Anthropic API key — used ONLY by the in-process rollout planner (POST /plan).
# NOT forwarded to the dispatched Claude Code subprocess: engines.py allowlists only
# CLAUDE_CODE_OAUTH_TOKEN for the claude engine, so this key never reaches the agent
# process. Forwarding it would flip billing off the Max/OAuth subscription onto
# pay-per-token API (see kb-01512).
ANTHROPIC_API_KEY=sk-ant-...

# =============================================================================
# Two-user split: agent subprocess user
# =============================================================================

# Username of the unprivileged agent user that owns workspace directories.
# Must match the --agent-user argument used when running setup-dispatch-host.sh.
# When set, the service spawns agent subprocesses via `sudo -u <value> -H`.
# Leave empty to disable user-switching (dev/test only).
#
# In single-user mode (DISPATCH_SINGLE_USER=1 at setup time), this MUST be left
# empty — the runtime _sudo_wrap shortcut is what gates single-user behaviour.
# setup-dispatch-host.sh strips this line from the .env if it appears under
# single-user mode.
DISPATCH_AGENT_SUBPROCESS_USER=dispatch

# =============================================================================
# Optional variables
# =============================================================================

# Maximum concurrent agent runs — set per host based on core count.
# Formula: num_cores × 1.5; e.g. 4 cores → 6, 8 cores → 12.
# Default (32) is too high for Pi-class hosts (e.g. pironman01 with 4 cores).
# See kb-01544 for capacity sizing rationale.
# DISPATCH_MAX_CONCURRENT_RUNS=6

# Workspace root for cloned repos (default: ~/workspace, relative to
# DISPATCH_AGENT_SUBPROCESS_USER's home when user-switching is enabled).
# DISPATCH_WORKSPACE_ROOT=/home/dispatch/workspace

# Claude Code turn and timeout limits.
# DISPATCH_MAX_TURNS=50
# DISPATCH_TIMEOUT_SECONDS=1800

# Ollama local inference — set OLLAMA_BASE_URL to route claude-code-ollama
# dispatches through a local Ollama instance instead of the Anthropic API.
# Root URL, no /v1 suffix (e.g. http://192.168.1.52:11434).
# OLLAMA_BASE_URL=
# OLLAMA_API_KEY=ollama
# OLLAMA_DEFAULT_MODEL=qwen3.6:35b

# =============================================================================
# Bedrock provider (corporate/port environments only)
# =============================================================================
# Use these when the Anthropic API is unreachable (e.g. corporate egress policy
# routes Claude access through Amazon Bedrock instead). The planner only uses
# these settings; build/manage agent subprocesses are unaffected.
#
# Provider gate: set to 'bedrock' to enable. Default 'anthropic' keeps the
# existing Anthropic API path byte-for-byte unchanged.
# DISPATCH_PLANNER_PROVIDER=anthropic
#
# Bedrock model ID. The global cross-region inference endpoint is the default;
# use the us. regional CRIS variant (e.g. us.anthropic.claude-sonnet-4-6) if
# your environment requires data-residency guarantees (+10% pricing applies).
# DISPATCH_PLANNER_BEDROCK_MODEL=global.anthropic.claude-sonnet-4-6
#
# AWS region for Bedrock API calls. IMPORTANT: the anthropic SDK reads
# AWS_REGION; if unset it defaults to us-east-1. AWS_PROFILE alone does NOT
# supply the region — the SDK does not read ~/.aws/config for the region.
# Credentials are resolved from the default AWS credential chain (AWS_PROFILE,
# env vars, instance metadata, etc.).
# AWS_REGION=us-east-1

# =============================================================================
# Authentication extras (must survive sudo boundary — listed in sudoers env_keep)
# =============================================================================

# Claude Code OAuth token — alternative to ANTHROPIC_API_KEY for OAuth-based
# authentication to Anthropic. Set this instead of ANTHROPIC_API_KEY when using
# Claude Code's OAuth login flow.
# CLAUDE_CODE_OAUTH_TOKEN=

# Knowledge base database URL — passed to agent subprocesses for KB access.
# This points at the PERSONAL KB; personal-kb inherits it (empty MCP env block).
# KB_DATABASE_URL=

# Team KB database URL — injected into the team-kb MCP server's env block by
# setup-dispatch-host.sh (Step 4.6). Required for team-kb registration; if unset,
# team-kb is skipped. Same personal_kb package, different database.
# TEAM_KB_DATABASE_URL=

# Anthropic API key for the KB MCP servers' own LLM calls (query planning, graph
# enrichment, summaries). Injected into the personal-kb AND team-kb MCP env blocks by
# setup-dispatch-host.sh (Step 4.6). MUST NOT be named ANTHROPIC_API_KEY: that name
# would reach Claude Code's launch env via the worker passthrough and flip billing from
# the Max subscription to pay-per-token API (see engines.py / kb-01512). Value is the
# same Anthropic key used elsewhere; the distinct name is the safety mechanism.
# KB_ANTHROPIC_API_KEY=

# Agent identity name — used for GTD comment attribution so comments appear
# under a specific agent name (e.g. claude-build-abc12345) rather than the
# generic service identity.
# AGENT_GTD_AGENT_NAME=
